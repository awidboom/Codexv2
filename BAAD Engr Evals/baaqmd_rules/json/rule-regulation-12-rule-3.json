    {
      "section_id": "600",
      "section_title": "MANUAL OF PROCEDURES (Not Included)",
      "history": [],
      "text": [
        "12-3-2REGULATION 12 MISCELLANEOUS STANDARDS OF PERFORMANCE ASPHALT AIR BLOWING"
      ],
      "subsections": []
    },
    {
      "section_id": "100",
      "section_title": "GENERAL",
      "history": [],
      "text": [],
      "subsections": []
    },
    {
      "section_id": "101",
      "section_title": "Description",
      "history": [],
      "text": [
        "This Rule applies to operations involving the air blowing of asphalt."
      ],
      "subsections": []
    },
    {
      "section_id": "300",
      "section_title": "STANDARDS",
      "history": [],
      "text": [],
      "subsections": []
    },
    {
      "section_id": "301",
      "section_title": "Processing of Gases",
      "history": [],
      "text": [
        "A person shall not engage in the air blowing of asphalt unless all gases, vapors and gas-entrained effluents are incinerated at temperatures of not less than 650oC (1202oF) for a period of not less than 0.3 seconds; or processed in a manner which is equally or more effective for the purpose of air pollution odor control as determined by the APCO."
      ],
      "subsections": []
    },
    {
      "section_id": "500",
      "section_title": "MONITORING AND RECORDS",
      "history": [],
      "text": [],
      "subsections": []
    },
    {
      "section_id": "501",
      "section_title": "Monitoring",
      "history": [],
      "text": [
        "A person incinerating or processing gases, vapors or gas-entrained effluents pursuant to this Rule shall provide, install, calibrate and maintain in good working order devices for indicating temperature, pressure or other operating conditions, as specified by the APCO."
      ],
      "subsections": []
    }
